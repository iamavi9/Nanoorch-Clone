# NanoOrch — Environment Configuration Reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values that apply to your deployment.
# Lines starting with # are comments and are ignored by the app.
#
# ── Docker Secrets (_FILE pattern) ───────────────────────────────────────────
# Every secret variable supports a companion <NAME>_FILE variant.
# When <NAME>_FILE is set the app reads the secret value from that file instead
# of the plain env var — real values never appear in `docker inspect Env`.
#
# Example:
#   SESSION_SECRET_FILE=/run/secrets/session_secret
#
# Run ./secrets/create-secrets.sh and use docker-compose.secrets.yml for a
# fully hardened deployment. See secrets/README.md for details.
# ─────────────────────────────────────────────────────────────────────────────


# ═════════════════════════════════════════════════════════════════════════════
# DATABASE
# ═════════════════════════════════════════════════════════════════════════════

# Individual Postgres credentials — used by docker-compose to create the DB
# and by the app to construct the connection string automatically.
POSTGRES_DB=nanoorch
POSTGRES_USER=nanoorch
POSTGRES_PASSWORD=change_me_in_production

# Direct connection URL — set this instead of (or in addition to) the
# individual POSTGRES_* vars above when connecting to an external / managed
# Postgres instance (e.g. AWS RDS, Supabase, Neon).
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
# _FILE variant: DATABASE_URL_FILE=/run/secrets/database_url
DATABASE_URL=


# ═════════════════════════════════════════════════════════════════════════════
# APPLICATION
# ═════════════════════════════════════════════════════════════════════════════

# Port the Express server listens on inside the container / host.
# docker-compose maps this to the host; change both sides if you need a
# different external port.  Defaults to 5000 when unset.
PORT=5000

# Set to "production" in live deployments to enable security hardening:
# HTTPS redirect middleware, strict cookie flags, minified error responses.
# Set to "development" locally for verbose logs and hot reload.
NODE_ENV=development

# Public-facing URL of your NanoOrch instance (required for SSO OIDC / SAML
# callback URLs and for generating correct redirect URIs).
# Must be the full origin (scheme + host + optional port) that your identity
# provider will redirect back to.  If unset, NanoOrch derives it from the
# incoming request headers (works correctly behind Nginx with
# X-Forwarded-Proto / X-Forwarded-Host).
#
# Examples:
#   APP_URL=https://nanoorch.your-company.com   # behind Nginx + TLS
#   APP_URL=http://1.2.3.4:5000                 # direct host access, no proxy
APP_URL=

# Sub-path prefix when NanoOrch is mounted at a non-root path behind a
# reverse proxy (e.g. /ai or /nanoorch).  Leave blank when serving from /.
# Example: BASE_PATH=/nanoorch
BASE_PATH=

# Set to "true" when the app runs behind a TLS-terminating reverse proxy
# (Nginx, Caddy, AWS ALB, etc.) so that session cookies are marked Secure.
# Leave unset or "false" for plain-HTTP local or Docker development.
COOKIE_SECURE=false


# ═════════════════════════════════════════════════════════════════════════════
# SESSION
# ═════════════════════════════════════════════════════════════════════════════

# Long random string used to sign session cookies.
# Generate with: openssl rand -hex 32
# _FILE variant: SESSION_SECRET_FILE=/run/secrets/session_secret
SESSION_SECRET=change_this_to_a_long_random_string_in_production


# ═════════════════════════════════════════════════════════════════════════════
# ADMIN ACCOUNT
# ═════════════════════════════════════════════════════════════════════════════

# These seed the first Super Admin account on startup — only takes effect if
# no admin user exists yet in the database.
# CHANGE ADMIN_PASSWORD before first boot.
# If ADMIN_PASSWORD is not set, the app generates a random password and prints
# a masked version to the console on first startup.
# _FILE variant: ADMIN_PASSWORD_FILE=/run/secrets/admin_password
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_before_first_boot


# ═════════════════════════════════════════════════════════════════════════════
# CREDENTIAL ENCRYPTION
# ═════════════════════════════════════════════════════════════════════════════

# 32-byte hex string (64 hex chars) used as the AES-256-GCM key for encrypting
# cloud integration credentials, vLLM API keys, and database connection strings
# at rest in Postgres.
#
# Generate with: openssl rand -hex 32
#
# Modes:
#   • 64-char hex string → used directly as the key (recommended).
#   • Any other non-empty string → treated as a passphrase; the key is derived
#     via PBKDF2 using ENCRYPTION_KEY_SALT (required in passphrase mode).
#   • Empty / unset → key derived from SESSION_SECRET (NOT recommended for
#     production — changing SESSION_SECRET will make stored credentials
#     unreadable).
#
# _FILE variant: ENCRYPTION_KEY_FILE=/run/secrets/encryption_key
ENCRYPTION_KEY=

# KDF salt used when ENCRYPTION_KEY is a passphrase (non-hex string) or when
# falling back to SESSION_SECRET.  Must be stable across restarts; changing it
# will invalidate all stored encrypted credentials.
# Generate with: openssl rand -hex 16
# Set to a fixed value for backward compatibility (e.g. nanoorch-kdf-salt-v1).
# _FILE variant: ENCRYPTION_KEY_SALT_FILE=/run/secrets/encryption_key_salt
ENCRYPTION_KEY_SALT=


# ═════════════════════════════════════════════════════════════════════════════
# AI PROVIDERS
# ═════════════════════════════════════════════════════════════════════════════
# At least one provider API key is required.  Others can be left blank.
# All key variables support the _FILE variant:
#   AI_INTEGRATIONS_OPENAI_API_KEY_FILE=/run/secrets/openai_api_key
#   AI_INTEGRATIONS_ANTHROPIC_API_KEY_FILE=/run/secrets/anthropic_api_key
#   AI_INTEGRATIONS_GEMINI_API_KEY_FILE=/run/secrets/gemini_api_key

# ── OpenAI ────────────────────────────────────────────────────────────────────
# API key for OpenAI (GPT-4o, GPT-4o mini, embeddings).
AI_INTEGRATIONS_OPENAI_API_KEY=
# Override the OpenAI API base URL — useful for Azure OpenAI endpoints or
# compatible third-party providers (e.g. Together AI, Groq).
# Default: https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ── Anthropic ─────────────────────────────────────────────────────────────────
# API key for Anthropic (Claude 3.5 Sonnet, Claude 3 Haiku, etc.).
AI_INTEGRATIONS_ANTHROPIC_API_KEY=
# Override the Anthropic API base URL. Default: https://api.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── Google Gemini ─────────────────────────────────────────────────────────────
# API key for Google Gemini (Gemini 2.0 Flash, Gemini 1.5 Pro, etc.).
AI_INTEGRATIONS_GEMINI_API_KEY=
# Override the Gemini API base URL.
# Default: https://generativelanguage.googleapis.com
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ── Ollama (self-hosted) ──────────────────────────────────────────────────────
# Ollama has no API key.  Configure its base URL per orchestrator in the UI.
# Typical value when Ollama runs on the same host: http://host.docker.internal:11434
# No env var is required here unless you want a global default.


# ═════════════════════════════════════════════════════════════════════════════
# SESSION STORE & RATE LIMITING  (Redis — optional)
# ═════════════════════════════════════════════════════════════════════════════

# When set, NanoOrch uses Redis for the session store and per-IP rate-limit
# counters — recommended for multi-replica production deployments.
# When unset, the app falls back to an in-process store (single-replica only).
#
# Format: redis://[:password@]host:port[/db]
# Examples:
#   REDIS_URL=redis://redis:6379             # docker-compose service name
#   REDIS_URL=redis://:mypassword@redis:6379 # with password
#   REDIS_URL=rediss://redis.example.com:6380 # TLS
REDIS_URL=


# ═════════════════════════════════════════════════════════════════════════════
# DOCKER AGENT SANDBOX
# ═════════════════════════════════════════════════════════════════════════════

# Path to the Docker socket.  When set, the app can spawn ephemeral containers
# for action tasks and code execution.  Omit (or set to empty) to disable
# Docker-based isolation and run tasks in-process instead.
DOCKER_SOCKET=/var/run/docker.sock

# Docker image used for action-task agent containers.
# Build with: docker build -t nanoorch-agent:latest ./agent
AGENT_IMAGE=nanoorch-agent:latest

# Docker image used for code-execution sandbox containers.
# Build with: docker build -t nanoorch-sandbox:latest ./agent/sandbox
SANDBOX_IMAGE=nanoorch-sandbox:latest

# OCI runtime for code-execution sandbox containers.
#   runsc — gVisor kernel-level isolation (requires gVisor on the host)
#   runc  — standard Docker runtime (simpler, less isolated)
SANDBOX_RUNTIME=runsc

# OCI runtime for agent action-task containers.
#   runsc — gVisor isolation (recommended for production)
#   runc  — standard Docker runtime
#   (blank) — use Docker's configured default (runc)
AGENT_RUNTIME=

# Absolute host path to a custom seccomp JSON profile applied to both agent
# and sandbox containers.  A hardened profile ships at agent/seccomp/nanoorch.json.
# Copy it to a stable host path and set:
#   SECCOMP_PROFILE=/etc/nanoorch/seccomp/nanoorch.json
SECCOMP_PROFILE=

# Inference proxy URL that Docker containers use to reach the NanoOrch
# internal /internal/proxy endpoint.  Automatically derived from the host
# network gateway on Docker Engine >= 20.10 (host.docker.internal).
# Override when running on older Docker Engine or custom bridge networks.
# Example: DOCKER_PROXY_URL=http://172.17.0.1:5000/internal/proxy
DOCKER_PROXY_URL=


# ═════════════════════════════════════════════════════════════════════════════
# KUBERNETES / K3S SANDBOX  (alternative to Docker — optional)
# ═════════════════════════════════════════════════════════════════════════════

# Set to "k3s" to route agent task execution through Kubernetes Jobs instead
# of local Docker containers.  Requires KUBECONFIG to point to a valid cluster.
# Omit (or leave blank) to use the Docker executor (default).
#   SANDBOX_MODE=k3s
SANDBOX_MODE=

# Absolute path to the kubeconfig file for the target cluster.
# Required when SANDBOX_MODE=k3s.
# Example: KUBECONFIG=/etc/nanoorch/kubeconfig.yaml
KUBECONFIG=

# Kubernetes namespace where agent Job resources are created.
# The namespace must already exist on the cluster.
# Default: agent-sandboxes
K3S_NAMESPACE=agent-sandboxes

# Inference proxy URL that K3s pods use to reach the NanoOrch internal proxy.
# Must be reachable from inside the cluster (use a Service or external IP).
# Default: http://nanoorch-app:3000/internal/proxy
K3S_PROXY_URL=http://nanoorch-app:5000/internal/proxy


# ═════════════════════════════════════════════════════════════════════════════
# MIGRATIONS
# ═════════════════════════════════════════════════════════════════════════════

# Absolute or relative path to the Drizzle migration SQL files directory.
# Override only when running migrations from a custom location (e.g. in a
# distroless container where the default relative path doesn't resolve).
# Default: resolved relative to the compiled server bundle.
MIGRATIONS_DIR=
